# Image versions (pinned)
VICTORIA_LOGS_VERSION=v1.50.0
VECTOR_VERSION=0.56.0-alpine
VICTORIA_METRICS_VERSION=v1.144.0
VMAGENT_VERSION=v1.144.0
PHOENIX_VERSION=version-17.2.0

# Network binding (127.0.0.1 = local only, 0.0.0.0 = all interfaces)
AGENT_LOGS_BIND=127.0.0.1

# Ports
VICTORIA_LOGS_PORT=9428
VECTOR_INGEST_PORT=8688
VECTOR_METRICS_PORT=9598
VICTORIA_METRICS_PORT=8428
PHOENIX_PORT=6006
PHOENIX_GRPC_PORT=4317

# Retention
VICTORIA_LOGS_RETENTION=7d
VICTORIA_METRICS_RETENTION=7d
PHOENIX_RETENTION_DAYS=7
